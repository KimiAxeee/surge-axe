[Script]
http-response ^https?:// script-path=https://raw.githubusercontent.com/APNA_USERNAME/surge-axe/main/scripts/token_extractor.js, requires-body=true, timeout=10, tag=AXE-TokenExtract

[MITM]
hostname = *
